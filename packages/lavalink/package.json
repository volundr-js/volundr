  },
  "keywords": ["discord", "lavalink", "music", "audio"],
  "author": "brviictoor",
  "license": "ISC",
  "dependencies": {
    "@volundr/client": "workspace:*",
    "@volundr/logger": "workspace:*",
    "@volundr/types": "workspace:*",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/ws": "^8.18.1"
  }
}
